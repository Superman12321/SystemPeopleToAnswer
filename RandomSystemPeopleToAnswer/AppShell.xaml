<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RandomSystemPeopleToAnswer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RandomSystemPeopleToAnswer"
    Shell.FlyoutBehavior="Disabled"
    Title="RandomSystemPeopleToAnswer"
    StyleClass="appShell">

    <TabBar>
        <ShellContent
            Title="Dodawanie uczniów do listy"
            ContentTemplate="{DataTemplate local:AddStudent}"
            Route="AddStudent"   
            />
        <ShellContent
            Title="Lista obecności uczniów"
            ContentTemplate="{DataTemplate local:AttendanceList}"
            Route="AttendanceList"   
            />
        <ShellContent
            Title="Edycja listy uczniów"
            ContentTemplate="{DataTemplate local:EditStudentList}"
            Route="EditStudentList"   
            />
        <ShellContent
            Title="Wylosowanie ucznia"
            ContentTemplate="{DataTemplate local:RandomStudent}"
            Route="RandomStudent"   
            />
    </TabBar>

</Shell>
